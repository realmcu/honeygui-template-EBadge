            <hg_label id="lbl_10" x="217" y="223" width="94" height="48" hAlign="CENTER" vAlign="MID" color="#ffffff" letterSpacing="0" lineSpacing="0" wordWrap="false" wordBreak="false" text="Yes" fontFile="/font/Inter_24pt_Regular.ttf" fontSize="20" zIndex="3" />
